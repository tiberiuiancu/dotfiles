{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

# packages.yaml hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.darwin.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF
{{ end -}}
